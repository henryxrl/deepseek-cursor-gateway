# ============================================================
# DeepSeek Cursor Gateway — Docker environment variables
# Usage: cp .env.example .env → edit → docker compose up -d
# See docs/deployment.md for full instructions.
# ============================================================

# --- Network -------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9000

# --- Upstream API --------------------------------------------
GATEWAY_BASE_URL=https://api.deepseek.com
GATEWAY_MODEL=deepseek-v4-pro
GATEWAY_THINKING=enabled                # enabled | disabled (per-request override: body field or model suffix -nothink)
GATEWAY_REASONING_EFFORT=max            # low | medium | high | max | xhigh
GATEWAY_REQUEST_TIMEOUT=300
GATEWAY_MAX_REQUEST_BODY_BYTES=20971520 # 20 MB
GATEWAY_MISSING_REASONING_STRATEGY=recover  # recover | reject
GATEWAY_USER_MESSAGE_SUFFIX=

# --- Traffic control -----------------------------------------
GATEWAY_UPSTREAM_MAX_INFLIGHT=2         # max concurrent upstream requests (0=unlimited)
GATEWAY_UPSTREAM_QUEUE_TIMEOUT_SECONDS=300

# --- Retry & backoff ---------------------------------------
GATEWAY_UPSTREAM_RETRY_ENABLED=1        # 1=on, 0=off
GATEWAY_UPSTREAM_RETRY_MAX_ATTEMPTS=3   # total attempts including the first try
GATEWAY_UPSTREAM_RETRY_BASE_DELAY_SECONDS=2
GATEWAY_UPSTREAM_RETRY_MAX_DELAY_SECONDS=30
GATEWAY_UPSTREAM_RETRY_JITTER_SECONDS=1
GATEWAY_UPSTREAM_RESPECT_RETRY_AFTER=1  # 1=honor Retry-After header
GATEWAY_UPSTREAM_COOLDOWN_ON_429=1      # 1=global cooldown after 429

# --- Optional request-start smoothing (advanced, disabled) ---
GATEWAY_REQUEST_START_RATE_LIMIT_ENABLED=0
# GATEWAY_REQUEST_START_RATE_PER_MINUTE=30
# GATEWAY_REQUEST_START_BURST=3

# --- Image handling ------------------------------------------
GATEWAY_IMAGE_HANDLING=strip            # strip | reject | ocr
# GATEWAY_VISION_WARMUP=warn            # off | warn | require
# GATEWAY_VISION_FALLBACK_BACKEND=tesseract  # optional fallback when LLM vision fails

# --- Vision / OCR (only used when image_handling=ocr) --------
# OpenAI-compatible vision model:
# GATEWAY_VISION_BACKEND=openai_compatible
# GATEWAY_VISION_BASE_URL=https://api.openai.com/v1
# GATEWAY_VISION_MODEL=gpt-4o-mini
# GATEWAY_VISION_API_KEY=sk-...
# GATEWAY_VISION_TIMEOUT=60
# GATEWAY_VISION_CONCURRENCY=0          # 0 = unlimited; use 1 or 2 for local LLMs

# Google Gemini:
# GATEWAY_VISION_BACKEND=gemini
# GATEWAY_VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GATEWAY_VISION_MODEL=gemini-2.0-flash
# GATEWAY_VISION_API_KEY=...
# GATEWAY_VISION_TIMEOUT=60

# Local Tesseract OCR:
# GATEWAY_VISION_BACKEND=tesseract
# GATEWAY_TESSERACT_LANG=eng+chi_sim    # English + Simplified Chinese

# --- Ngrok tunnel --------------------------------------------
GATEWAY_NGROK=0                         # 1 = enabled, 0 = disabled
# GATEWAY_NGROK_URL=                    # custom ngrok URL / reserved domain

# --- Reasoning cache -----------------------------------------
GATEWAY_REASONING_CONTENT_PATH=/data/reasoning_content.sqlite3
GATEWAY_REASONING_CACHE_MAX_AGE_SECONDS=2592000  # 30 days
GATEWAY_REASONING_CACHE_MAX_ROWS=100000

# --- Display -------------------------------------------------
GATEWAY_DISPLAY_REASONING=1             # 1 = on, 0 = off
GATEWAY_COLLAPSIBLE_REASONING=1         # 1 = on, 0 = off

# --- Misc ----------------------------------------------------
GATEWAY_CORS=0                          # 1 = on, 0 = off
GATEWAY_VERBOSE=0                       # 1 = on, 0 = off
# GATEWAY_TRACE_DIR=/data/traces
# GATEWAY_CONFIG=/data/config.yaml
